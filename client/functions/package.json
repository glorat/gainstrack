{
  "name": "functions",
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "lint": "eslint src",
    "build": "tsc",
    "dev": "tsc -w",
    "serve": "pnpm run build && firebase emulators:start --only functions",
